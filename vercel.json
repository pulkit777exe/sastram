{
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/update-threads",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-blobs",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 9 * * *"
    }
  ]
}
