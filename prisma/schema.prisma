generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── ENUMS ──────────────────────────────────────────────

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum ProfilePrivacy {
  PUBLIC
  PRIVATE
  FOLLOWERS_ONLY
}

enum CommunityVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum SectionVisibility {
  PUBLIC
  PRIVATE
  RESTRICTED
}

enum SectionRole {
  OWNER
  MODERATOR
  MEMBER
}

enum MemberStatus {
  ACTIVE
  INVITED
  LEFT
  REMOVED
}

enum NotificationType {
  REPLY
  MENTION
  REACTION
  INVITATION
  SYSTEM
  AI_INSIGHT // new: AI flagged something relevant to user
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum ReportCategory {
  SPAM
  HARASSMENT
  MISINFORMATION
  ADULT_CONTENT
  OTHER
}

enum AppealStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum DigestFrequency {
  DAILY
  WEEKLY
  NEVER
}

enum AttachmentType {
  IMAGE
  GIF
  VIDEO
  FILE
}

// ── CORE USERS ─────────────────────────────────────────

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  emailVerified Boolean @default(false)
  name          String?
  image         String?
  bio           String?
  location      String?
  website       String?
  github        String?
  twitter       String?
  avatarUrl     String?
  bannerUrl     String?

  // Preferences stored as JSON — avoids NotificationSettings table
  // Shape: { emailDigest: 'weekly'|'daily'|'never', pushEnabled: bool,
  //          theme: 'light'|'dark', aiSummaryEnabled: bool }
  preferences Json @default("{}")

  status           UserStatus     @default(ACTIVE)
  role             Role           @default(USER)
  profilePrivacy   ProfilePrivacy @default(PUBLIC)
  reputationPoints Int            @default(0)
  followerCount    Int            @default(0)
  followingCount   Int            @default(0)
  isPro            Boolean        @default(false)
  lastSeenAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  communities   Community[]          @relation("CommunityCreator")
  sections      Section[]            @relation("SectionCreator")
  messages      Message[]
  reactions     Reaction[]
  memberships   SectionMember[]
  notifications Notification[]
  reports       Report[]             @relation("Reporter")
  invitations   ThreadInvitation[]   @relation("InvitationSender")
  bans          UserBan[]            @relation("BannedUser")
  issuedBans    UserBan[]            @relation("BanIssuer")
  followers     UserFollow[]         @relation("Follower")
  following     UserFollow[]         @relation("Following")
  bookmarks     UserBookmark[]
  reputation    UserReputation?
  badges        UserBadgeEarned[]
  activities    UserActivity[]
  pollVotes     PollVote[]
  subscriptions ThreadSubscription[]
  appeals       Appeal[]             @relation("AppealSubmitter")
  moderatedAppeals Appeal[]         @relation("AppealModerator")

  // AI features
  aiSearchSessions AiSearchSession[]
  expertiseAreas   UserExpertise[]

  @@index([email])
  @@index([status])
  @@index([lastSeenAt])
  @@map("users")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String    @unique
  providerId   String
  userId       String
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@map("verifications")
}

// ── COMMUNITY & SECTIONS ───────────────────────────────

model Community {
  id          String              @id @default(cuid())
  title       String
  slug        String              @unique
  description String?
  visibility  CommunityVisibility @default(PUBLIC)
  // Settings: { allowPolls, requireApproval, aiSummaryEnabled }
  settings    Json                @default("{}")
  createdBy   String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  creator  User      @relation("CommunityCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  sections Section[]

  @@index([slug])
  @@index([visibility])
  @@map("communities")
}

model Section {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  description  String?
  visibility   SectionVisibility @default(PUBLIC)
  messageCount Int               @default(0)
  memberCount  Int               @default(0)
  communityId  String?
  createdBy    String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // AI fields
  // resolutionScore: 0-100, how well resolved this thread is
  resolutionScore Int?
  // lastVerifiedAt: when AI last checked if content is still accurate
  lastVerifiedAt  DateTime?
  // isOutdated: AI flagged that newer info contradicts this thread
  isOutdated      Boolean   @default(false)
  // aiSummary: cached AI summary of the thread
  aiSummary       String?   @db.Text
  // threadDna: { questionType, expertiseLevel, topics[], readTimeMinutes }
  threadDna       Json?

  creator       User                 @relation("SectionCreator", fields: [createdBy], references: [id])
  community     Community?           @relation(fields: [communityId], references: [id])
  messages      Message[]
  members       SectionMember[]
  invitations   ThreadInvitation[]
  bans          UserBan[]
  bookmarks     UserBookmark[]
  tags          ThreadTagRelation[]
  poll          Poll?
  subscriptions ThreadSubscription[]
  relatedTo     ThreadRelation[]     @relation("SourceThread")
  relatedFrom   ThreadRelation[]     @relation("TargetThread")

  @@index([slug])
  @@index([visibility])
  @@index([communityId])
  @@index([createdBy])
  @@index([resolutionScore])
  @@map("sections")
}

model SectionMember {
  id        String       @id @default(cuid())
  sectionId String
  userId    String
  role      SectionRole  @default(MEMBER)
  status    MemberStatus @default(ACTIVE)
  joinedAt  DateTime     @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sectionId, userId])
  @@index([sectionId])
  @@index([userId])
  @@map("section_members")
}

// ── MESSAGES (with tree threading) ────────────────────

model Message {
  id           String    @id @default(cuid())
  content      String    @db.Text
  sectionId    String
  senderId     String
  parentId     String? // null = root post
  depth        Int       @default(0) // 0=root, 1=reply, 2=reply-to-reply, max 4
  isEdited     Boolean   @default(false)
  isPinned     Boolean   @default(false)
  likeCount    Int       @default(0) // denormalized for perf
  replyCount   Int       @default(0) // denormalized for perf
  isAiResponse Boolean   @default(false) // true when @ai generated this
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // soft delete — keep for tree integrity

  section     Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sender      User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  parent      Message?         @relation("MessageReplies", fields: [parentId], references: [id])
  replies     Message[]        @relation("MessageReplies")
  attachments Attachment[]
  reactions   Reaction[]
  reports     Report[]
  editHistory MessageEdit[]
  mentions    MessageMention[]
  appeals     Appeal[]         @relation("MessageAppeal")

  @@index([sectionId])
  @@index([sectionId, createdAt])
  @@index([senderId])
  @@index([parentId]) // critical for tree building
  @@index([parentId, sectionId]) // critical for tree building
  @@index([depth])
  @@map("messages")
}

model MessageEdit {
  id        String   @id @default(cuid())
  messageId String
  content   String   @db.Text
  editedAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_edits")
}

model MessageMention {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_mentions")
}

model Attachment {
  id        String         @id @default(cuid())
  messageId String
  url       String
  type      AttachmentType
  name      String?
  size      BigInt?
  createdAt DateTime       @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("reactions")
}

// ── SOCIAL ─────────────────────────────────────────────

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

model UserBookmark {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread Section @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@index([userId])
  @@map("user_bookmarks")
}

// ── NOTIFICATIONS ──────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String?
  data      Json? // flexible payload per type
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ── SUBSCRIPTIONS (replaces NewsletterSubscription + ThreadDigest) ──

model ThreadSubscription {
  id        String          @id @default(cuid())
  threadId  String
  userId    String?
  email     String?
  frequency DigestFrequency @default(WEEKLY)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())

  thread Section @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@unique([threadId, email])
  @@index([threadId])
  @@index([userId])
  @@map("thread_subscriptions")
}

model ModerationRule {
  id        String   @id @default(cuid())
  pattern   String
  category  String
  action    String
  severity  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([severity])
  @@map("moderation_rules")
}

model Appeal {
  id          String       @id @default(cuid())
  messageId   String
  userId      String
  moderatorId String?
  status      AppealStatus @default(PENDING)
  reason      String
  response    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  resolvedAt  DateTime?

  message   Message          @relation("MessageAppeal", fields: [messageId], references: [id], onDelete: Cascade)
  user      User             @relation("AppealSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  moderator User?            @relation("AppealModerator", fields: [moderatorId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([userId])
  @@index([moderatorId])
  @@index([status])
  @@index([createdAt])
  @@map("appeals")
}

model Report {
  id         String         @id @default(cuid())
  messageId  String
  reporterId String
  category   ReportCategory
  details    String?        @db.Text
  status     ReportStatus   @default(PENDING)
  resolvedBy String?
  resolution String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter User    @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([status])
  @@index([reporterId])
  @@map("reports")
}

model UserBan {
  id        String    @id @default(cuid())
  userId    String
  bannedBy  String
  reason    String
  threadId  String? // null = site-wide ban
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user   User     @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  issuer User     @relation("BanIssuer", fields: [bannedBy], references: [id], onDelete: Cascade)
  thread Section? @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([threadId])
  @@map("user_bans")
}

// ── TAGS ───────────────────────────────────────────────

model ThreadTag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  color     String   @default("#3736fc")
  createdAt DateTime @default(now())

  threads ThreadTagRelation[]

  @@index([slug])
  @@map("thread_tags")
}

model ThreadTagRelation {
  threadId String
  tagId    String

  thread Section   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  tag    ThreadTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([threadId, tagId])
  @@index([tagId])
  @@map("thread_tag_relations")
}

// ── POLLS ──────────────────────────────────────────────

model Poll {
  id        String    @id @default(cuid())
  threadId  String    @unique
  question  String
  options   Json // string[]
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  thread Section    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  votes  PollVote[]

  @@map("polls")
}

model PollVote {
  id          String   @id @default(cuid())
  pollId      String
  userId      String
  optionIndex Int
  createdAt   DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
  @@map("poll_votes")
}

// ── REPUTATION & BADGES ────────────────────────────────

model UserReputation {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_reputation")
}

model UserBadge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String?
  color       String   @default("#3736fc")
  criteria    Json
  createdAt   DateTime @default(now())

  earnedBy UserBadgeEarned[]

  @@map("user_badges")
}

model UserBadgeEarned {
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge UserBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@map("user_badges_earned")
}

// Single activity table replaces AuditLog + UserActivity
// type examples: 'MESSAGE_CREATED', 'THREAD_JOINED', 'AI_SEARCH', 'BADGE_EARNED'
model UserActivity {
  id         String   @id @default(cuid())
  userId     String
  type       String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
  @@index([entityType, entityId])
  @@map("user_activities")
}

// ── INVITATIONS ────────────────────────────────────────

model ThreadInvitation {
  id        String           @id @default(cuid())
  threadId  String
  senderId  String
  email     String
  status    InvitationStatus @default(PENDING)
  token     String           @unique @default(cuid())
  expiresAt DateTime?
  createdAt DateTime         @default(now())

  thread Section @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User    @relation("InvitationSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([threadId, email])
  @@index([token])
  @@map("thread_invitations")
}

// ── AI SEARCH ──────────────────────────────────────────

// Groups a user's search session (one query = one session)
model AiSearchSession {
  id              String   @id @default(cuid())
  userId          String
  query           String   @db.Text
  queryHash       String // sha256 of normalized query for dedup
  queryType       String? // factual | opinion | technical | comparison
  cacheHit        Boolean  @default(false)
  processingMs    Int?
  createdAt       DateTime @default(now())
  lastPrewarmedAt DateTime?

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  results AiSearchResult[]

  @@index([userId])
  @@index([queryHash])
  @@index([createdAt])
  @@map("ai_search_sessions")
}

// Stores the synthesized result (shared across users via queryHash)
model AiSearchResult {
  id            String   @id @default(cuid())
  sessionId     String
  queryHash     String
  synthesis     String   @db.Text
  confidence    Int
  sourceCount   Int
  conflictFound Boolean  @default(false)
  conflictData  Json?
  sources       Json // Source[] — title, url, domain, tier, confidence
  expiresAt     DateTime // TTL varies by query type
  hitCount      Int      @default(0)
  createdAt     DateTime @default(now())

  session AiSearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([queryHash])
  @@index([expiresAt])
  @@map("ai_search_results")
}

// ── AI FEATURES ────────────────────────────────────────

// Cross-thread semantic relationships (powers "Related Resolutions")
model ThreadRelation {
  id             String   @id @default(cuid())
  sourceThreadId String
  targetThreadId String
  similarity     Float // 0.0 - 1.0 cosine similarity
  createdAt      DateTime @default(now())

  source Section @relation("SourceThread", fields: [sourceThreadId], references: [id], onDelete: Cascade)
  target Section @relation("TargetThread", fields: [targetThreadId], references: [id], onDelete: Cascade)

  @@unique([sourceThreadId, targetThreadId])
  @@index([sourceThreadId, similarity])
  @@map("thread_relations")
}

// Expert Passport — per-domain expertise tracking
model UserExpertise {
  id           String   @id @default(cuid())
  userId       String
  domain       String // 'react', 'kubernetes', 'security', etc.
  score        Int      @default(0) // 0-100
  helpfulCount Int      @default(0) // answers marked helpful in this domain
  totalCount   Int      @default(0) // total answers in this domain
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain])
  @@index([userId])
  @@index([domain, score])
  @@map("user_expertise")
}
