{
  "name": "sastram",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx server.ts",
    "dev:worker": "tsx worker/index.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:server": "NODE_ENV=production tsx server.ts",
    "start:worker": "node worker/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "test": "node --import tsx --import tsconfig-paths/register --import ./test/setup.ts ./node_modules/mocha/bin/mocha.js test/**/*.test.mts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,jsx}": "eslint --fix",
    "**/*.{json,md,yml,yaml,css,html}": "prettier --write"
  },
  "overrides": {
    "undici": "^8.1.0",
    "defu": "^6.1.5",
    "minimatch": "^9.0.7",
    "picomatch": "^4.0.4",
    "flatted": "^3.4.1",
    "flatted@<3.4.1": "3.4.1",
    "follow-redirects@<1.16.0": "1.16.0",
    "hono@<4.12.14": "4.12.14",
    "@hono/node-server@<1.19.13": "1.19.13"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.4",
    "global-jsdom": "^29.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prisma": "^7.8.0",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "@sentry/nextjs": "^10",
    "zustand": "^5.0.12"
  }
}
