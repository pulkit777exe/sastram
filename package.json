{
  "name": "sastram",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx server.ts",
    "dev:worker": "tsx worker/index.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:server": "NODE_ENV=production tsx server.ts",
    "start:worker": "node worker/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "test": "node --import tsx --import tsconfig-paths/register --import ./test/setup.ts ./node_modules/mocha/bin/mocha.js test/**/*.test.mts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,jsx}": "eslint --fix",
    "**/*.{json,md,yml,yaml,css,html}": "prettier --write"
  },
  "overrides": {
    "axios": "^1.15.2",
    "undici": "^8.1.0",
    "defu": "^6.1.5",
    "minimatch": "^9.0.7",
    "picomatch": "^4.0.4",
    "flatted": "^3.4.1",
    "js-yaml@<5.0.1": "5.0.1",
    "flatted@<3.4.1": "3.4.1",
    "follow-redirects@<1.15.12": "1.15.12",
    "hono@<4.12.14": "4.12.14",
    "@hono/node-server@<1.19.13": "1.19.13"
  },
  "devDependencies": {
    "tsconfig-paths": "^4.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "dependencies": {
    "@sentry/nextjs": "^10"
  }
}
