# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=                    # PostgreSQL connection string (required)
DATABASE_URL_UNPOOLED=           # Unpooled connection for migrations (optional)

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=                       # Redis connection string (optional, used by BullMQ/rate-limit)
REDIS_HOST=127.0.0.1             # Redis host (fallback if REDIS_URL not set)
REDIS_PORT=6379                  # Redis port
REDIS_PASSWORD=                  # Redis password (optional)
REDIS_USERNAME=                  # Redis username (optional)
REDIS_TLS=false                  # Enable TLS for Redis connections
UPSTASH_REDIS_REST_URL=          # Upstash REST URL (alternative to REDIS_URL)
UPSTASH_REDIS_REST_TOKEN=        # Upstash REST token

# ─── Auth ────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=              # Better Auth secret, min 32 chars (required)
BETTER_AUTH_URL=                 # Better Auth base URL, e.g. http://localhost:3000 (required)
GITHUB_CLIENT_ID=                # GitHub OAuth client ID (optional)
GITHUB_CLIENT_SECRET=            # GitHub OAuth client secret (optional)
GOOGLE_CLIENT_ID=                # Google OAuth client ID (optional)
GOOGLE_CLIENT_SECRET=            # Google OAuth client secret (optional)

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=             # Public app URL, e.g. http://localhost:3000 (required)
PORT=3000                        # Server port
NODE_ENV=development             # development | production | test

# ─── AI Providers ────────────────────────────────────────────────────────────
AI_PROVIDER=gemini               # gemini | openai — which AI backend to use
GEMINI_API_KEY=                  # Google Gemini API key (optional, needed if AI_PROVIDER=gemini)
OPENAI_API_KEY=                  # OpenAI API key (optional, needed if AI_PROVIDER=openai)
AI_ANALYSIS_MESSAGE_LIMIT=50     # Max messages to send to AI for analysis
GEMINI_FLASH_MODEL=gemini-2.5-flash   # Gemini Flash model ID
GEMINI_PRO_MODEL=gemini-1.5-pro       # Gemini Pro model ID
GEMINI_LITE_MODEL=gemini-2.0-flash-lite  # Gemini Lite model ID
GEMINI_SEARCH_MODEL=gemini-2.0-flash  # Gemini Search model ID
OPENAI_MODEL=gpt-4o-mini         # OpenAI model ID

# ─── Storage (Vercel Blob) ──────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=           # Vercel Blob read/write token (optional, needed for uploads)

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com         # SMTP server host
SMTP_PORT=587                    # SMTP server port
SMTP_SECURE=false                # Enable TLS for SMTP
SMTP_USER=                       # SMTP username (optional)
SMTP_PASS=                       # SMTP password (optional)
SMTP_FROM=Sastram <noreply@sastram.com>  # From address for emails

# ─── Cron & Rate Limiting ───────────────────────────────────────────────────
CRON_SECRET=                     # Bearer token for cron endpoints, min 32 chars (optional)
RATE_LIMIT_ENABLED=true          # Enable Redis-based rate limiting
CONTENT_MODERATION_ENABLED=false # Enable AI content moderation

# ─── Moderation ──────────────────────────────────────────────────────────────
MODERATION_CONFIDENCE_THRESHOLD=0.7  # ML confidence threshold for moderation actions

# ─── Search Keys ─────────────────────────────────────────────────────────────
SASTRAM_EXA_KEY=                 # Exa search API key (optional)
SASTRAM_TAVILY_KEY=              # Tavily search API key (optional)
SASTRAM_GEMINI_KEY=              # Gemini search API key (optional)

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=                      # Sentry DSN (optional)
SENTRY_ORG=                      # Sentry org slug (optional)
SENTRY_PROJECT=                  # Sentry project slug (optional)
SENTRY_AUTH_TOKEN=               # Sentry auth token (optional)

# ─── Queue Workers ──────────────────────────────────────────────────────────
QUEUE_WORKERS_ENABLED=true       # Enable BullMQ background workers
