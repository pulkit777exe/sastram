# ─── Core (required) ────────────────────────────────────────────────
DATABASE_URL=                              # PostgreSQL connection string (Neon: append ?pgbouncer=true)
BETTER_AUTH_SECRET=                        # Auth signing secret (min 32 chars)
BETTER_AUTH_URL=http://localhost:3000      # Auth base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000" # Public app URL

# ─── Email (Resend, required) ───────────────────────────────────────
RESEND_API_KEY=                            # Resend API key
RESEND_FROM="Sastram <noreply@sastram.com>" # From address
RESEND_TEMPLATE_OTP=                       # Resend template id: login OTP
RESEND_TEMPLATE_INVITATION=                # Resend template id: thread invitation
RESEND_TEMPLATE_THREAD_SUMMARY=            # Resend template id: thread summary
RESEND_TEMPLATE_PASSWORD_RESET=            # Resend template id: password reset
RESEND_TEMPLATE_WELCOME=                   # Resend template id: welcome

# ─── Redis / rate limiting (optional; rate limiting degrades without it) ──
REDIS_URL=                                 # ioredis TCP URL (pub/sub, queues)
UPSTASH_REDIS_REST_URL=                    # Upstash REST URL (rate limit + quotas)
UPSTASH_REDIS_REST_TOKEN=                  # Upstash REST token

# ─── Background jobs (QStash, optional) ─────────────────────────────
QSTASH_URL=                                # QStash base URL
QSTASH_TOKEN=                              # QStash publish token
QSTASH_CURRENT_SIGNING_KEY=                # QStash request-verification key
QSTASH_NEXT_SIGNING_KEY=                   # QStash key rotation

# ─── Scheduled jobs ─────────────────────────────────────────────────
CRON_SECRET=                               # Bearer token for /api/cron/* (min 32 chars)

# ─── AI providers (optional; at least one needed for AI features) ────
AI_PROVIDER=gemini                         # gemini | openai
GEMINI_API_KEY=                            # Google Gemini key
OPENAI_API_KEY=                            # OpenAI key

# ─── AI search (optional; server-side fallback keys, user keys win) ──
SASTRAM_EXA_KEY=                           # Exa search key
SASTRAM_TAVILY_KEY=                        # Tavily search key
SASTRAM_GEMINI_KEY=                        # Gemini key for forum-search fallback

# ─── OAuth (optional) ───────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADMIN_ID=
GOOGLE_ADMIN_SECRET=

# ─── Storage (optional) ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=                     # Vercel Blob token

# ─── Feature flags ──────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true                    # Set false to disable rate limiting
CONTENT_MODERATION_ENABLED=false           # Enable AI image/content moderation

# ─── Observability (optional) ───────────────────────────────────────
SENTRY_DSN=                                # Sentry DSN
LOG_LEVEL=info                             # debug | info | warn | error
MODERATION_WEBHOOK_URL=                    # Optional moderator notification webhook
