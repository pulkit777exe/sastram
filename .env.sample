GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADMIN_ID=
GOOGLE_ADMIN_SECRET=

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
CRON_SECRET=

DATABASE_URL=

BLOB_READ_WRITE_TOKEN=

NEXT_PUBLIC_APP_URL="http://localhost:3000"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Sastram <noreply@sastram.com>"

# AI Search (optional server-side fallback keys — user keys take priority)
SASTRAM_EXA_KEY=
SASTRAM_TAVILY_KEY=
SASTRAM_GEMINI_KEY=

# ─── BullMQ / Redis Queue ─────────────────────────────────────────────
# Primary Redis connection (BullMQ uses IORedis under the hood).
# Set REDIS_URL for full URL format (e.g. Upstash, Redis Cloud).
#   REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
# OR use individual fields:
#   REDIS_HOST=127.0.0.1
#   REDIS_PORT=6379
#   REDIS_PASSWORD=
#   REDIS_TLS=true    # set to 'true' for Upstash/Redis Cloud TLS
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_TLS=

# Upstash REST fallback (some legacy integrations use this)
UPSTASH_REDIS_REST_URL=

# Queue worker control (for Vercel)
# Workers auto-start in the Node.js runtime via instrumentation.ts.
# Set to 'false' to prevent auto-start (e.g. during builds or SSR-only deployments).
QUEUE_WORKERS_ENABLED=true
